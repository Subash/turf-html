  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Subash/turf-html/issues"
  },
  "homepage": "https://github.com/Subash/turf-html#readme",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
