{
  "name": "turf-html",
  "version": "0.1.0",
  "description": "HTML Macros with Kit Support",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/turf.d.ts",
      "default": "./lib/turf.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepack": "npm run build",
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Subash/turf-html.git"
  },
  "keywords": [
    "kit",
